# BOM agent runtime
# Leave unset to auto-detect from cwd / package layout (recommended for local dev).
# BOM_REPO_ROOT=/Users/you/work/supply-chain-impact-analysis-agent
BOM_NEO4J_URI=bolt://localhost:7687
BOM_NEO4J_USER=neo4j
BOM_NEO4J_PASSWORD=password
BOM_DUCKDB_PATH=data/bom.duckdb
BOM_AGENT_PORT=8080

# app/agent -> LiteLLM (OpenAI-compatible /v1)
OPENAI_API_BASE=http://127.0.0.1:4000/v1
OPENAI_API_KEY=sk-litellm-local
OPENAI_MODEL=bom-gemini-3.5-flash
LLM_GATEWAY=litellm

# Google AI Studio key for gemini/gemini-3.5-flash (LiteLLM upstream)
GEMINI_API_KEY=
# UPSTREAM_OPENAI_API_KEY=   # for config/litellm.yaml model bom-openai-planner

# LiteLLM proxy
LITELLM_MASTER_KEY=sk-litellm-local
LITELLM_PORT=4000

# Langfuse (developer observability; not shown in the web UI)
# uv sync --extra observability
# Docker: ./scripts/start_stack.sh
# LANGFUSE_HOST or LANGFUSE_BASE_URL (either works)
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PORT=3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
