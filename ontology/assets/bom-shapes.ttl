@prefix bom: <neo4j://graph.schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

bom:ComponentShape a sh:NodeShape ;
  sh:targetClass bom:Component ;
  sh:property [ sh:path bom:id ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [ sh:path bom:name ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [ sh:path bom:material ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [ sh:path bom:cost ;
    sh:minExclusive 0.0 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [ sh:path bom:graph_id ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [ sh:path bom:as_of ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [ sh:path bom:graph_contract_version ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [ sh:path bom:USED_IN ;
    sh:class bom:Product ;
    sh:nodeKind sh:IRI ;
  ] ;
  sh:property [ sh:path bom:SUPPLIED_BY ;
    sh:class bom:Supplier ;
    sh:nodeKind sh:IRI ;
  ] ;
  sh:property [ sh:path bom:INPUT_OF ;
    sh:class bom:Process ;
    sh:nodeKind sh:IRI ;
  ] .

bom:ProcessShape a sh:NodeShape ;
  sh:targetClass bom:Process ;
  sh:property [ sh:path bom:id ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [ sh:path bom:name ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [ sh:path bom:work_center ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [ sh:path bom:cycle_time_min ;
    sh:minExclusive 0.0 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [ sh:path bom:graph_id ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [ sh:path bom:as_of ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [ sh:path bom:graph_contract_version ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

bom:SupplierShape a sh:NodeShape ;
  sh:targetClass bom:Supplier ;
  sh:property [ sh:path bom:id ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [ sh:path bom:company_name ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [ sh:path bom:country ;
    sh:datatype xsd:string ;
    sh:minLength 2 ;
    sh:maxLength 2 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [ sh:path bom:risk_level ;
    sh:datatype xsd:string ;
    sh:in ( "Low" "Medium" "High" ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [ sh:path bom:graph_id ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [ sh:path bom:as_of ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [ sh:path bom:graph_contract_version ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] .

bom:ProductShape a sh:NodeShape ;
  sh:targetClass bom:Product ;
  sh:property [ sh:path bom:id ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [ sh:path bom:name ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [ sh:path bom:version ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [ sh:path bom:graph_id ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [ sh:path bom:as_of ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [ sh:path bom:graph_contract_version ;
    sh:datatype xsd:string ;
    sh:minLength 1 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
  ] ;
  sh:property [ sh:path bom:PRODUCED_BY ;
    sh:class bom:Process ;
    sh:nodeKind sh:IRI ;
  ] .
